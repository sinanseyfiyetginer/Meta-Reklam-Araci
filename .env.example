# Meta Reklam Aracı — Örnek .env Dosyası
# Bu dosyayı kopyalayıp adını .env yap, gerçek değerlerle doldur.
# .env dosyasını ASLA kimseyle paylaşma, GitHub'a gönderme!

# ── META (ZORUNLU) ────────────────────────────────────────────────
META_ACCESS_TOKEN=buraya_token_yapistir
META_AD_ACCOUNT_ID=act_buraya_hesap_id_gelecek

# ── ANTHROPIC / CLAUDE AI (AI yorum için) ────────────────────────
ANTHROPIC_API_KEY=buraya_anthropic_key_gelecek

# ── E-POSTA GÖNDERİMİ (Gmail SMTP) ──────────────────────────────
# Kurulum:
#   1. Gmail → Google Hesabım → Güvenlik → 2 adımlı doğrulama AÇIK olmalı
#   2. Güvenlik → Uygulama şifreleri → "Meta Reklam Aracı" → Oluştur
#   3. 16 haneli şifreyi buraya yapıştır (boşluklar dahil yazabilirsin)
GMAIL_EMAIL=senin@gmail.com
GMAIL_APP_SIFRE=xxxx xxxx xxxx xxxx

# ── WHATSAPP GÖNDERİMİ (Twilio - Opsiyonel) ─────────────────────
# Kurulum:
#   1. twilio.com'a kaydol (ücretsiz, 15$ deneme kredisi ile başlar)
#   2. Console → Account SID ve Auth Token'ı kopyala
#   3. Messaging → Try it out → WhatsApp Sandbox numarasını kopyala
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=+14155238886

# ── DİĞER ────────────────────────────────────────────────────────
VARSAYILAN_DIL=tr
PARA_BIRIMI=TRY
